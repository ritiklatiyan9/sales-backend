# ── booking-api environment ──
# Serves both the REST API and the React SPA (no separate frontend service).
# Shares the SAME Postgres / Redis / JWT / S3 as the accounting backend.
PORT=8000

# Postgres (same DB as accounting — additive tables only)
DB_HOST=your-neon-host
DB_PORT=5432
DB_NAME=rgaccount
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSL=true

# JWT — MUST match the accounting backend so tokens are interchangeable
JWT_ACCESS_SECRET=someJwtSecret
JWT_REFRESH_SECRET=someRefreshSecret

# S3 (same bucket as accounting). In production set this so OCR can read uploads; in local
# dev the on-disk fallback works because OCR now runs inside this same process.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# CORS origin for the booking-ui SPA (comma-separated allowed; * for dev)
CORS_ORIGIN=*

# ── OCR (in-process, Groq vision) ──
# OCR runs inside booking-api now — no Redis broker, no Python worker. A single Groq
# multimodal call reads the document image AND extracts KYC fields in ~1 second.
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# (optional) Groq text model used by the /kyc/case/:id/extract-preview endpoint.
GROQ_MODEL=llama-3.3-70b-versatile
# (optional) max documents OCR'd concurrently in-process.
OCR_CONCURRENCY=3
