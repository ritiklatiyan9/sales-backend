# ── booking-api environment ──
# Serves both the REST API and the React SPA (no separate frontend service).
# Shares the SAME Postgres / Redis / JWT / S3 as the accounting backend.
PORT=8000

# Postgres (same DB as accounting — additive tables only)
DB_HOST=your-neon-host
DB_PORT=5432
DB_NAME=rgaccount
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSL=true

# JWT — MUST match the accounting backend so tokens are interchangeable
JWT_ACCESS_SECRET=someJwtSecret
JWT_REFRESH_SECRET=someRefreshSecret

# Google Sign-In (Firebase) — path to the Firebase Admin service-account key.
# The frontend's Firebase popup sends an ID token that this key verifies. Only emails
# that already exist on a users row may sign in with Google (no self-signup).
FIREBASE_SERVICE_ACCOUNT=secrets/firebase-service-account.json
# Optional fallback: verify plain Google Identity Services tokens against this
# OAuth 2.0 Web client ID instead (used only if the Firebase key is absent).
GOOGLE_CLIENT_ID=

# ── Admin login OTP (Nodemailer) ──
# When set, super_admin/admin/sub_admin logins require a 6-digit code emailed to
# the account's address (agents stay single-step). Leave unset to disable.
# Gmail: host smtp.gmail.com, port 587, and an App Password (not the account password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: display sender, e.g. "Defence Garden ERP <no-reply@defencegarden.in>"
SMTP_FROM=

# Receipt/agreement QR verification — MUST match the accounting backend (shared HMAC).
RECEIPT_VERIFY_SECRET=
# Public verify page for booking/agreement receipt QRs (accounting frontend).
PUBLIC_VERIFY_URL=http://localhost:5173/verify-receipt
# Public verify page for DRAW registration/slip QRs (this booking frontend).
DRAW_PUBLIC_VERIFY_URL=http://localhost:5173/verify/draw

# S3 (same bucket as accounting). In production set this so OCR can read uploads; in local
# dev the on-disk fallback works because OCR now runs inside this same process.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# CORS origin for the booking-ui SPA (comma-separated allowed; * for dev)
CORS_ORIGIN=https://sales-dg-frontend.vercel.app,https://www.dgbooking.com,https://dgbooking.com,http://localhost:5173,http://localhost:3000

# ── OCR (in-process, Groq vision) ──
# OCR runs inside booking-api now — no Redis broker, no Python worker. A single Groq
# multimodal call reads the document image AND extracts KYC fields in ~1 second.
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# (optional) Groq text model used by the /kyc/case/:id/extract-preview endpoint.
GROQ_MODEL=llama-3.3-70b-versatile
# (optional) max documents OCR'd concurrently in-process.
OCR_CONCURRENCY=50
